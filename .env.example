# ─── 🏔️ BALTA VISTA — COMPLETE ENVIRONMENT VARIABLES ───
# Every env var used by the application. Required ones are marked.
# Copy this file to .env.local and fill in your values.

# ─── REQUIRED ───

# Your production domain (e.g. https://balta-vista.com)
NEXT_PUBLIC_SITE_URL=

# WhatsApp number for guest contact (format: 92300XXXXXXX, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Strong random string for admin dashboard access
ADMIN_KEY=

# Resend API key for transactional emails (get at https://resend.com)
RESEND_API_KEY=

# Email addresses for sending and receiving
EMAIL_FROM=bookings@yourdomain.com
ADMIN_EMAIL=reservations@yourdomain.com

# ─── OPTIONAL ───

# Google Maps embed URL (iframe src) for location page
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Google reCAPTCHA v3 keys (for spam prevention on booking form)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Booking webhook (forward leads to Zapier/Make/CRM)
BOOKING_WEBHOOK_URL=
BOOKING_WEBHOOK_SECRET=

# Analytics webhook (forward events to reporting endpoint)
ANALYTICS_WEBHOOK_URL=
ANALYTICS_WEBHOOK_SECRET=

# Payment webhook secret (register {SITE_URL}/api/payment/webhook with Easypaisa/JazzCash)
PAYMENT_WEBHOOK_SECRET=

# CSRF token secret (auto-generated if empty)
CSRF_SECRET=

# Session secret for admin login (auto-generated if empty)
SESSION_SECRET=

# Force HTTPS redirect (set true for production without Vercel)
FORCE_HTTPS=false
